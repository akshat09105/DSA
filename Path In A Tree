bool GetPath(TreeNode<int>* root,vector<int>&ans,int k){
	if(root==nullptr){
		return false;
	}
	ans.push_back(root->data);
	if(root->data==k){
		return true;
	}
	if(GetPath(root->left,ans,k)||GetPath(root->right,ans,k)){
		return true;
	}
	ans.pop_back();
	return false;

}
vector<int> pathInATree(TreeNode<int> *root, int x)
{
    // Write your code here.
	vector<int>ans;
	GetPath(root,ans,x);
	return ans;

}
